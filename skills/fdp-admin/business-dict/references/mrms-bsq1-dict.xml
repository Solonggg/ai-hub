        <properties>
            <compare_field>_custom__input_</compare_field>
            <con>EQ</con>
            <field_key>bsq03</field_key>
            <unit>NULL</unit>
            <value>{{VALUE}}</value>
        </properties>
    </conObj>
    <id>1656561581176385536</id>
    <name>病案数据字典</name>
    <primary_key>id</primary_key>
    <render_key type="List">
        <value>bsq02</value>
    </render_key>
    <search_key type="List">
        <value>abbrw</value>
        <value>bsq02</value>
        <value>bsq01</value>
        <value>abbrp</value>
    </search_key>
    <show_key type="List">
        <value>bsq02</value>
    </show_key>
    <type>TABLELIST</type>
    <value_key>bsq01</value_key>
</wordbook>
