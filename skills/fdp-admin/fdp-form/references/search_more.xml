<!--
  SEARCH_MORE · 多选字典（标签多选）
  占位符：
    {{NAME}}            字段中文名
    {{VAL_KEY}}         字段标识
    {{WORDBOOK_BLOCK}}  <wordbook>...</wordbook> 整段，从 business-dict skill 对应字典的片段拷贝，
                        并把其中 {{VALUE}} 替换为用户确认过的分类码
  与 SEARCH 的差别：html_type=SEARCH_MORE + multi_select=1，无 show_type / buttonOpenWindowType
-->
            <properties>
                <auto_branch>0</auto_branch>
                <elem_width type="Integer">3</elem_width>
                <first_line_two_spaces>0</first_line_two_spaces>
                <free_entry>0</free_entry>
                <hide_title>0</hide_title>
                <html_type>SEARCH_MORE</html_type>
                <is_back>0</is_back>
                <is_edit>1</is_edit>
                <is_empty>1</is_empty>
                <is_null>1</is_null>
                <is_recommend>0</is_recommend>
                <is_show>0</is_show>
                <is_system_fields>1</is_system_fields>
                <multi_select>1</multi_select>
                <name>{{NAME}}</name>
                <val_key>{{VAL_KEY}}</val_key>
                {{WORDBOOK_BLOCK}}
            </properties>
