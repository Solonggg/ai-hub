<!--
  TEXTAREA · 多行文本域
  占位符：
    {{NAME}}       字段中文名
    {{VAL_KEY}}    字段标识
    {{MAX_LENGTH}} 最大长度（默认 500）
  说明：
    elem_width 通常为 12（占满整行）
-->
            <properties>
                <auto_branch>0</auto_branch>
                <delete_before_after_spaces>1</delete_before_after_spaces>
                <elem_width type="Integer">12</elem_width>
                <first_line_two_spaces>0</first_line_two_spaces>
                <hide_title>0</hide_title>
                <html_type>TEXTAREA</html_type>
                <is_back>0</is_back>
                <is_edit>1</is_edit>
                <is_empty>1</is_empty>
                <is_fast_reply_field>0</is_fast_reply_field>
                <is_null>1</is_null>
                <is_show>0</is_show>
                <is_system_fields>1</is_system_fields>
                <name>{{NAME}}</name>
                <val_key>{{VAL_KEY}}</val_key>
                <validate>
                    <max_length>{{MAX_LENGTH}}</max_length>
                </validate>
            </properties>
