<!--
  DIGITAL · 数字（用户说 NUMBER 也映射到这里）
  占位符：
    {{NAME}}           字段中文名
    {{VAL_KEY}}        字段标识
    {{DECIMAL_LENGTH}} 小数位：NUMBER(n,0)→0；NUMBER(n,m)→m
  说明：
    decimal_policy=1 为常规舍入策略
-->
            <properties>
                <auto_branch>0</auto_branch>
                <elem_width type="Integer">3</elem_width>
                <first_line_two_spaces>0</first_line_two_spaces>
                <hide_title>0</hide_title>
                <html_type>DIGITAL</html_type>
                <is_back>0</is_back>
                <is_edit>1</is_edit>
                <is_empty>1</is_empty>
                <is_null>1</is_null>
                <is_show>0</is_show>
                <is_system_fields>1</is_system_fields>
                <name>{{NAME}}</name>
                <val_key>{{VAL_KEY}}</val_key>
                <validate>
                    <decimal_length>{{DECIMAL_LENGTH}}</decimal_length>
                    <decimal_policy>1</decimal_policy>
                </validate>
            </properties>
