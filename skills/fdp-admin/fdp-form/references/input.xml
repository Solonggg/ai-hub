<!--
  INPUT · 单行文本框
  占位符：
    {{NAME}}       字段中文名
    {{VAL_KEY}}    字段标识（全表唯一）
    {{MAX_LENGTH}} 最大长度（默认 300）
  可选调整：
    is_empty=0 表示必填（默认 1 可空）
    is_show=1 表示表单展示（默认 0 隐藏）
-->
            <properties>
                <auto_branch>0</auto_branch>
                <delete_before_after_spaces>1</delete_before_after_spaces>
                <elem_width type="Integer">3</elem_width>
                <first_line_two_spaces>0</first_line_two_spaces>
                <hide_title>0</hide_title>
                <html_type>INPUT</html_type>
                <is_back>0</is_back>
                <is_edit>1</is_edit>
                <is_empty>1</is_empty>
                <is_fast_reply_field>0</is_fast_reply_field>
                <is_null>1</is_null>
                <is_show>0</is_show>
                <is_system_fields>1</is_system_fields>
                <name>{{NAME}}</name>
                <val_key>{{VAL_KEY}}</val_key>
                <validate>
                    <max_length>{{MAX_LENGTH}}</max_length>
                </validate>
            </properties>
